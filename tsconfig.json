{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "@main/*": ["./src/main/*"],
      "@core/*": ["./src/core/*"],
      "@renderer/*": ["./src/renderer/*"]
    }
  },
  "include": ["src/main/**/*", "src/core/**/*"],
  "exclude": [
    "src/renderer/**/*",
    "src/core/__tests__/**/*",
    "src/**/*.test.ts",
    "node_modules",
    "dist"
  ]
}
